<Window x:Class="MusicShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="RootWindow"
        Title="ToolBridge"
        Width="1440"
        Height="900"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Icon="Assets/toolbridge-icon.png"
        Background="{DynamicResource SurfaceBrush}"
        TextElement.Foreground="{DynamicResource PrimaryTextBrush}"
        PreviewKeyDown="RootWindow_PreviewKeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/ToolBridge.UI.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <!-- Sol navigasyon -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="18,22,18,18">
                                <!-- TOOLBRIDGE_COPYRIGHT_FOOTER -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource LineBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="4,12,4,0"
                        Margin="8,16,8,0">
                    <TextBlock Text="&#x00A9; 2026 Tolga Demirel. T&#x00FC;m haklar&#x0131; sakl&#x0131;d&#x0131;r."
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                </Border>
<StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="2,0,0,26" VerticalAlignment="Center">
                        <Image Source="Assets/toolbridge-icon.png"
                               Width="36"
                               Height="36"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True" />
                        <TextBlock Text="ToolBridge"
                                   FontFamily="{StaticResource MenuFont}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                    </StackPanel>

                    <Border Background="{DynamicResource PanelAltBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8"
                            Margin="0,0,0,2"
                            ClipToBounds="False">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.06" Color="#000000" />
                        </Border.Effect>
                        <ItemsControl ItemsSource="{Binding PrimaryNavigation}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource GlowNavButtonStyle}"
                                            Command="{Binding DataContext.SelectNavCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Border Height="1" Background="{DynamicResource LineBrush}" Margin="12,24,12,18" />

                    <Grid Margin="12,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Online Kullanıcılar"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding OnlineUserCountText}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="8,0,2,0"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Border Style="{StaticResource InputWrapperBorderStyle}" Margin="8,0,8,10">
                        <TextBox Text="{Binding LeftOnlineUserSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ShadcnTextBoxInputStyle}"
                                 ToolTip="Online kullanıcı ara" />
                    </Border>

                    <ScrollViewer MaxHeight="245" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding LeftFilteredOnlineUsers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="30" Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="8"
                                                Height="8"
                                                CornerRadius="4"
                                                Background="#22A55A"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource SoftTextBrush}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Border Grid.Column="2"
                                                Width="10"
                                                Height="10"
                                                CornerRadius="5"
                                                Background="#D97706"
                                                Margin="8,0,2,0"
                                                Visibility="{Binding TransferNotificationVisibility}"
                                                ToolTip="{Binding TransferNotificationText}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Ana içerik -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="{DynamicResource SurfaceBrush}" Margin="0,0,12,0">
            <Grid>
                <StackPanel Margin="32,30,30,42">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedPage}" Value="Ayarlar">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedPageTitle}" FontFamily="{StaticResource DisplayFont}" FontSize="40" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                            <TextBlock Text="{Binding SelectedPageSubtitle}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="1,8,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>

                    <Border Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22"
                            Margin="0,26,0,6"
                            Effect="{StaticResource SoftShadow}"
                            AllowDrop="True"
                            DragOver="UploadDropzone_DragOver"
                            Drop="UploadDropzone_Drop">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPage}" Value="Yazdırma">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="46"
                                        Height="46"
                                        CornerRadius="8"
                                        Background="{Binding ActiveAccentSoftBrush}"
                                        BorderBrush="{Binding ActiveAccentBorderBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="&#xE898;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="20"
                                               Foreground="{Binding ActiveAccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="14,1,0,0">
                                    <TextBlock Text="Dosya Yükle"
                                       FontFamily="{StaticResource DisplayFont}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="20"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Yazdırma işlemi için dosyanızı seçin veya bu alana sürükleyip bırakın."
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               FontSize="13"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="Dosya Seç"
                                        Style="{StaticResource ShadcnButtonStyle}"
                                        Command="{Binding BrowseUploadFilesCommand}"
                                        VerticalAlignment="Top"
                                        Height="36"
                                        Width="132"
                                        Padding="18,0" />
                            </Grid>

                            <Border Background="{DynamicResource PanelMutedBrush}"
                                    CornerRadius="8"
                                    Margin="0,18,0,0"
                                    Padding="0"
                                    AllowDrop="True"
                                    DragOver="UploadDropzone_DragOver"
                                    Drop="UploadDropzone_Drop">
                                <Grid MinHeight="164">
                                    <Rectangle RadiusX="8"
                                               RadiusY="8"
                                               Stroke="{DynamicResource LineBrush}"
                                               StrokeThickness="1.5"
                                               StrokeDashArray="5 4"
                                               Fill="Transparent" />
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                TextBlock.TextAlignment="Center">
                                        <Border Width="52"
                                                Height="52"
                                                CornerRadius="8"
                                                Background="{DynamicResource PanelBrush}"
                                                BorderBrush="{DynamicResource LineBrush}"
                                                BorderThickness="1"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE8E5;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="22"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="Dosyaları buraya bırakın"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Margin="0,14,0,0" />
                                        <TextBlock Text="Sürükle-bırak veya Dosya Seç ile ekle"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="13"
                                                   Margin="0,5,0,0" />
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,12,0,0">
                                            <TextBlock Text="Dosya Seç ekranında Ctrl+A ile toplu seçim yapabilirsiniz"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="12" />
                                            <TextBlock Text="  •  "
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding UploadLimitText}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding UploadFileCountText}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="Listeyi Temizle"
                                        Style="{StaticResource ShadcnGhostButtonStyle}"
                                        Command="{Binding ClearUploadFilesCommand}"
                                        VerticalAlignment="Center"
                                        Height="36"
                                        Width="132"
                                        Padding="18,0" />
                                <Button Grid.Column="2"
                                        Content="{Binding PrintButtonText}"
                                        Style="{StaticResource ShadcnButtonStyle}"
                                        Command="{Binding PrintDocumentsCommand}"
                                        VerticalAlignment="Center"
                                        Height="36"
                                        Width="132"
                                        Padding="18,0"
                                        Margin="8,0,0,0" />
                            </Grid>

                            <Border Background="{DynamicResource PanelMutedBrush}"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,10,0,0"
                                    Padding="6">
                                <ScrollViewer MaxHeight="280"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="True"
                                              PanningMode="VerticalOnly">
                                    <ItemsControl ItemsSource="{Binding UploadFiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource PanelBrush}"
                                                        BorderBrush="{DynamicResource LineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="12"
                                                        Margin="0,0,8,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="46" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="40"
                                                                Height="40"
                                                                CornerRadius="8"
                                                                Background="{DynamicResource ChipBrush}"
                                                                BorderBrush="{DynamicResource LineBrush}"
                                                                BorderThickness="1">
                                                            <TextBlock Text="&#xE8A5;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="17"
                                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1"
                                                                    VerticalAlignment="Center"
                                                                    Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding FileName}"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Foreground="{DynamicResource MutedTextBrush}"
                                                                       FontSize="12"
                                                                       Margin="0,2,0,0">
                                                                <Run Text="{Binding SizeText}" />
                                                                <Run Text="  •  " />
                                                                <Run Text="{Binding Extension}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Style="{StaticResource ShadcnGhostButtonStyle}"
                                                                Width="34"
                                                                Height="34"
                                                                Padding="0"
                                                                ToolTip="Kaldır"
                                                                Command="{Binding DataContext.RemoveUploadFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}">
                                                            <Viewbox Width="15" Height="15" Stretch="Uniform">
                                                                <Path Fill="{DynamicResource MutedTextBrush}"
                                                                      Data="M6,2 L10,2 L11,3 L14,3 L14,5 L2,5 L2,3 L5,3 Z M4,6 L12,6 L11.25,14 L4.75,14 Z M6,7.5 L7,7.5 L7,12.5 L6,12.5 Z M9,7.5 L10,7.5 L10,12.5 L9,12.5 Z" />
                                                            </Viewbox>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <TextBlock Text="{Binding UploadStatusMessage}"
                                       Foreground="{Binding UploadStatusBrush}"
                                       FontSize="12"
                                       Margin="2,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                    </Border>


                    <!-- Transfer sayfası -->
                    <StackPanel Margin="0,26,0,28"
                                AllowDrop="True"
                                DragOver="TransferDropzone_DragOver"
                                Drop="TransferDropzone_Drop">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedPage}" Value="Transfer">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Border Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="22"
                                Effect="{StaticResource SoftShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="0.95*" />
                                </Grid.ColumnDefinitions>

                                <!-- Transfer edilecek dokümanlar -->
                                <StackPanel Grid.Column="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Dosya Gönder"
                                                       FontFamily="{StaticResource DisplayFont}"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="Online personele göndereceğiniz dosya ve dokümanları bu alanda hazırlayın."
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="12"
                                                       Margin="0,5,0,0"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Dosya Seç"
                                                Style="{StaticResource ThemedPrimaryButtonStyle}"
                                                Background="{Binding ActiveAccentBrush}"
                                                BorderBrush="{Binding ActiveAccentBrush}"
                                                Command="{Binding BrowseTransferFilesCommand}"
                                                Height="32"
                                                Width="104"
                                                Padding="12,0"
                                                Margin="12,0,0,0"
                                                VerticalAlignment="Top" />
                                        <Button Grid.Column="2"
                                                Content="Listeyi Temizle"
                                                Style="{StaticResource ShadcnSecondaryButtonStyle}"
                                                Command="{Binding ClearTransferFilesCommand}"
                                                Height="32"
                                                MinWidth="156"
                                                Padding="14,0"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Top" />
                                    </Grid>

                                    <Border AllowDrop="True"
                                            DragOver="TransferDropzone_DragOver"
                                            Drop="TransferDropzone_Drop"
                                            Background="Transparent"
                                            Margin="0,18,0,14"
                                            Height="172">
                                        <Grid>
                                            <Rectangle Fill="{DynamicResource PanelMutedBrush}"
                                                       Stroke="{DynamicResource LineBrush}"
                                                       StrokeThickness="1.4"
                                                       StrokeDashArray="4 4"
                                                       RadiusX="12"
                                                       RadiusY="12" />
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        MaxWidth="430">
                                                <Border Width="38"
                                                        Height="38"
                                                        CornerRadius="9"
                                                        Background="{DynamicResource PanelBrush}"
                                                        BorderBrush="{DynamicResource LineBrush}"
                                                        BorderThickness="1"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,10">
                                                    <Viewbox Width="18" Height="18" Stretch="Uniform">
                                                        <Path Stroke="{Binding ActiveAccentBrush}"
                                                              StrokeThickness="1.7"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"
                                                              Data="M3,6 L13,6 M10,3 L13,6 L10,9 M13,12 L3,12 M6,9 L3,12 L6,15" />
                                                    </Viewbox>
                                                </Border>
                                                <TextBlock Text="Dosya seç veya sürükle-bırak"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center" />
                                                <TextBlock Text="Dosya Seç ekranında Ctrl+A ile toplu seçim yapılabilir."
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="50 MB üzeri dosyalar parçalı aktarılır • Checksum doğrulaması yapılır"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="{Binding TransferSendHintText}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="2,0,0,10" />

                                    <Border BorderBrush="{DynamicResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Background="{DynamicResource PanelMutedBrush}">
                                        <StackPanel>
                                            <Grid Height="38" Background="{DynamicResource PanelAltBrush}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="124" />
                                                    <ColumnDefinition Width="46" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Dosya" Grid.Column="0" Margin="12,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                                <TextBlock Text="Boyut" Grid.Column="1" Margin="10,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                                <TextBlock Text="Durum" Grid.Column="2" Margin="10,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                                                <TextBlock Text="" Grid.Column="3" />
                                            </Grid>
                                            <Border Height="1" Background="{DynamicResource LineBrush}" />
                                            <ScrollViewer MinHeight="126" MaxHeight="210" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding ConvertTransferFiles}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid MinHeight="44" Background="{DynamicResource PanelBrush}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="110" />
                                                                    <ColumnDefinition Width="124" />
                                                                    <ColumnDefinition Width="46" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding FileName}" Grid.Column="0" Margin="12,0" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding SizeText}" Grid.Column="1" Margin="10,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource MutedTextBrush}" />
                                                                <StackPanel Grid.Column="2"
                                                                            Margin="10,6,10,6"
                                                                            VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding ProgressText}"
                                                                               Style="{StaticResource TbListRowMutedTextBlockStyle}" />
                                                                    <ProgressBar Value="{Binding Progress}"
                                                                                 Style="{StaticResource TbTransferProgressBarStyle}"
                                                                                 Visibility="{Binding ProgressVisibility}"
                                                                                 Margin="0,5,0,0" />
                                                                </StackPanel>
                                                                <Button Grid.Column="3"
                                                                        Style="{StaticResource ShadcnGhostButtonStyle}"
                                                                        Width="30"
                                                                        Height="30"
                                                                        Padding="0"
                                                                        HorizontalAlignment="Center"
                                                                        ToolTip="Listeden kaldır"
                                                                        Command="{Binding DataContext.RemoveTransferFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Viewbox Width="14" Height="14" Stretch="Uniform">
                                                                        <Path Fill="{DynamicResource MutedTextBrush}"
                                                                              Data="M6,2 L10,2 L11,3 L14,3 L14,5 L2,5 L2,3 L5,3 Z M4,6 L12,6 L11.25,14 L4.75,14 Z M6,7.5 L7,7.5 L7,12.5 L6,12.5 Z M9,7.5 L10,7.5 L10,12.5 L9,12.5 Z" />
                                                                    </Viewbox>
                                                                </Button>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="{Binding TransferStatusMessage}"
                                               Foreground="{Binding TransferStatusBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="4,14,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Online personeller -->
                                <Border Grid.Column="2"
                                        Background="{DynamicResource PanelMutedBrush}"
                                        BorderBrush="{DynamicResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Online Personeller"
                                                   FontFamily="{StaticResource DisplayFont}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBlock Text="Alıcıyı seçin, dosyaları ekleyin ve Gönder butonuna basın."
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="13"
                                                   Margin="0,5,0,0"
                                                   TextWrapping="Wrap" />
                                                                                <Grid Margin="0,14,0,10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding OnlineUserCountText}"
