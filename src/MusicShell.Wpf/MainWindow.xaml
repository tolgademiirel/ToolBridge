                            CornerRadius="8"
                            Padding="16"
                            Margin="0,18,0,0"
                            Effect="{StaticResource SoftShadow}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Sistem Durumu"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontSize="21"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <TextBlock Text="{Binding ConvertEngineStatusSummary}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Yenile"
                                        Style="{StaticResource ShadcnSecondaryButtonStyle}"
                                        Command="{Binding RefreshSystemStatusCommand}"
                                        Height="32"
                                        MinWidth="78" />
                            </Grid>

                            <Border Background="{DynamicResource PanelMutedBrush}"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="0,12,0,0">
                                <ItemsControl ItemsSource="{Binding ConvertEngineStatuses}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="8"
                                                        Height="8"
                                                        CornerRadius="4"
                                                        Background="{Binding StatusBrush}"
                                                        VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" Margin="10,0,8,0">
                                                    <TextBlock Text="{Binding Name}"
                                                               Style="{StaticResource TbListRowTextBlockStyle}" />
                                                    <TextBlock Text="{Binding Purpose}"
                                                               Style="{StaticResource TbListRowMutedTextBlockStyle}"
                                                               Margin="0,2,0,0" />
                                                    <TextBlock Text="{Binding DetailText}"
                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0" />
                                                    <TextBlock Text="{Binding VersionText}"
                                                               Visibility="{Binding VersionVisibility}"
                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding StatusText}"
                                                           Foreground="{Binding StatusBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,18,0,0"
                            Effect="{StaticResource SoftShadow}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="İş Kuyruğu"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontSize="21"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <TextBlock Text="{Binding OperationQueueCountText}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Tamamlananları Sil"
                                        Style="{StaticResource ShadcnSecondaryButtonStyle}"
                                        Command="{Binding ClearCompletedJobsCommand}"
                                        Height="32"
                                        MinWidth="132" />
                            </Grid>

                            <Border Background="{DynamicResource PanelMutedBrush}"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="0,12,0,0"
                                    MinHeight="120">
                                <Grid>
                                    <TextBlock Text="Kuyrukta işlem yok."
                                               Visibility="{Binding OperationQueueEmptyVisibility}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    <ScrollViewer MaxHeight="240"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Visibility="{Binding OperationQueueListVisibility}">
                                        <ItemsControl ItemsSource="{Binding OperationJobs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource PanelBrush}"
                                                            BorderBrush="{DynamicResource LineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="9"
                                                            Padding="10"
                                                            Margin="0,0,0,10">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Title}"
                                                                           Style="{StaticResource TbListRowTextBlockStyle}" />
                                                                <TextBlock Text="{Binding Summary}"
                                                                           Style="{StaticResource TbListRowMutedTextBlockStyle}"
                                                                           Margin="0,2,0,0" />
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                                                    Content="İptal"
                                                                    Style="{StaticResource ShadcnDestructiveButtonStyle}"
                                                                    Command="{Binding DataContext.CancelOperationJobCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Visibility="{Binding CancelButtonVisibility}"
                                                                    Height="28"
                                                                    MinWidth="58" />
                                                            <ProgressBar Grid.Row="1"
                                                                         Grid.ColumnSpan="2"
                                                                         Value="{Binding Progress}"
                                                                         Style="{StaticResource TbTransferProgressBarStyle}"
                                                                         Margin="0,10,0,0" />
                                                            <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding DetailText}"
                                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                                           FontSize="11"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding StatusText}"
                                                                           Foreground="{Binding StatusBrush}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Margin="8,0,0,0" />
                                                            </Grid>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Gelen transfer pop-up -->
        <Grid Grid.ColumnSpan="3"
              Panel.ZIndex="99"
              Background="#99000000"
              Visibility="{Binding IncomingTransferModalVisibility}">
            <Border Width="560"
                    MaxHeight="640"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="28,26,28,14">
                        <TextBlock Text="{Binding IncomingTransferTitle}"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding IncomingTransferSubtitle}"
                                   FontSize="14"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="410">
                        <StackPanel Margin="28,0,28,20">
                            <Border Background="{DynamicResource PanelMutedBrush}"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Tarih" Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding IncomingTransferDateText}" Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />

                                    <TextBlock Text="Toplam boyut" Grid.Row="1" Grid.Column="0" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding IncomingTransferSizeText}" Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,10,0,0" TextWrapping="Wrap" />

                                    <TextBlock Text="Kaydedilecek klasör" Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,10,0,0" />
                                    <TextBlock Text="{Binding IncomingTransferDestinationText}" Grid.Row="2" Grid.Column="1" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,10,0,0" TextWrapping="Wrap" />
                                </Grid>
                            </Border>

                            <TextBlock Text="Dosya bilgileri"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,0,0,8" />

                            <Border BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Background="{DynamicResource PanelBrush}">
                                <StackPanel>
                                    <Grid Height="36" Background="{DynamicResource PanelAltBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="132" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Dosya" Grid.Column="0" Margin="12,0" Style="{StaticResource TbListHeaderTextBlockStyle}" />
                                        <TextBlock Text="Boyut" Grid.Column="1" Margin="12,0" Style="{StaticResource TbListHeaderTextBlockStyle}" />
                                        <TextBlock Text="Durum" Grid.Column="2" Margin="12,0" Style="{StaticResource TbListHeaderTextBlockStyle}" />
                                    </Grid>
                                    <Border Height="1" Background="{DynamicResource LineBrush}" />
                                    <ItemsControl ItemsSource="{Binding IncomingTransferFiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="38" Background="{DynamicResource PanelBrush}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="132" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="12,6,8,6" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FileName}" Style="{StaticResource TbListRowTextBlockStyle}" />
                                                        <TextBlock Text="{Binding TransferModeText}" Style="{StaticResource TbListRowMutedTextBlockStyle}" Margin="0,2,0,0" />
                                                        <TextBlock Text="{Binding ChecksumText}" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding SizeText}" Grid.Column="1" Margin="12,0" Style="{StaticResource TbListRowMutedTextBlockStyle}" />
                                                    <StackPanel Grid.Column="2" Margin="12,6,12,6" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ProgressText}" Style="{StaticResource TbListRowMutedTextBlockStyle}" />
                                                        <ProgressBar Value="{Binding Progress}"
                                                                     Style="{StaticResource TbTransferProgressBarStyle}"
                                                                     Visibility="{Binding ProgressVisibility}"
                                                                     Margin="0,5,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Background="{DynamicResource PanelAltBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="0,1,0,0"
                            CornerRadius="0,0,16,16"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="Kapat"
                                    Style="{StaticResource ShadcnSecondaryButtonStyle}"
                                    Command="{Binding CloseIncomingTransferCommand}"
                                    Height="36"
                                    Width="96" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="Reddet"
                                        Style="{StaticResource ShadcnSecondaryButtonStyle}"
                                        Command="{Binding RejectIncomingTransferCommand}"
                                        Height="36"
                                        Width="104"
                                        Margin="0,0,10,0" />
                                <Button Content="Kabul Et"
                                        Style="{StaticResource ThemedPrimaryButtonStyle}"
                                        Background="{Binding ActiveAccentBrush}"
                                        BorderBrush="{Binding ActiveAccentBrush}"
                                        Command="{Binding AcceptIncomingTransferCommand}"
                                        Height="36"
                                        Width="116" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
