        <Style x:Key="GlowNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SoftTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Outer"
                                Background="Transparent"
                                CornerRadius="18"
                                Padding="2"
                                ClipToBounds="False">
                            <Grid ClipToBounds="False">
                                <!-- Prompttaki radial-gradient + glow davranışının WPF karşılığı -->
                                <Border x:Name="GlowLayer"
                                        Background="{Binding GlowBrush}"
                                        CornerRadius="18"
                                        Opacity="0"
                                        Margin="10,7">
                                    <Border.Effect>
                                        <BlurEffect Radius="4" />
                                    </Border.Effect>
                                </Border>

                                <Border x:Name="GlassLayer"
                                        Background="{DynamicResource PanelBrush}"
                                        BorderBrush="{Binding IconBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Opacity="0" />

                                <Grid x:Name="ContentHost"
                                      Margin="14,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Name="IconGlyph"
                                               Text="{Binding Icon}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="17"
                                               Foreground="{Binding IconBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />

                                    <TextBlock x:Name="MenuLabel"
                                               Grid.Column="1"
                                               FontFamily="{StaticResource MenuFont}"
                                               Text="{Binding Title}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0" />
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GlowLayer" Property="Opacity" Value="0.34" />
                                <Setter TargetName="GlowLayer" Property="Margin" Value="2,3" />
                                <Setter TargetName="GlassLayer" Property="Opacity" Value="0.86" />
                                <Setter TargetName="GlassLayer" Property="Background" Value="{DynamicResource PanelBrush}" />
                                <Setter TargetName="GlassLayer" Property="Effect" Value="{StaticResource SoftShadow}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ContentHost" Property="Opacity" Value="0.82" />
                            </Trigger>

                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="GlowLayer" Property="Opacity" Value="0.28" />
                                <Setter TargetName="GlowLayer" Property="Margin" Value="3,4" />
                                <Setter TargetName="GlassLayer" Property="Opacity" Value="0.92" />
                                <Setter TargetName="GlassLayer" Property="Background" Value="{DynamicResource PanelBrush}" />
                                <Setter TargetName="GlassLayer" Property="Effect" Value="{StaticResource SoftShadow}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

