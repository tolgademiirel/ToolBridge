        <!--
            Ark UI checkbox modelinin WPF karşılığıdır.
            Transfer Alımı ve Gece Modu gibi açık/kapalı seçeneklerde kullanılır.
        -->
        <Style x:Key="ArkCheckboxStyle" TargetType="CheckBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="CheckRoot"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="4"
                                    Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="2"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Viewbox x:Name="CheckIcon"
                                         Width="12"
                                         Height="12"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Stretch="Uniform"
                                         Visibility="Collapsed">
                                    <Path Data="M 2.5 6.5 L 5.25 9.25 L 10 3.75"
                                          Stroke="White"
                                          StrokeThickness="2.2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                </Viewbox>
                            </Border>

                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckRoot" Property="BorderBrush" Value="{DynamicResource MutedTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckRoot" Property="Background" Value="{DynamicResource ButtonPrimaryBrush}" />
                                <Setter TargetName="CheckRoot" Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBrush}" />
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <!--
            Ayarlar sayfası tercih seçimleri.
            21st.dev checkbox-group davranışının WPF karşılığı: yuvarlatılmış satır,
            hover arka planı, seçili satır vurgusu ve net check göstergesi.
        -->
        <Style x:Key="SettingsPreferenceCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Regular" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="FocusRing"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="22"
                                Padding="2">
                            <Border x:Name="ItemRoot"
                                    Background="Transparent"
                                    CornerRadius="20"
                                    Padding="12,10"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="CheckRoot"
                                            Width="18"
                                            Height="18"
                                            CornerRadius="5"
                                            Background="{DynamicResource PanelBrush}"
                                            BorderBrush="{DynamicResource LineBrush}"
                                            BorderThickness="1.5"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <Viewbox x:Name="CheckIcon"
                                                 Width="12"
                                                 Height="12"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Stretch="Uniform"
                                                 Visibility="Collapsed">
                                            <Path Data="M 2.5 6.5 L 5.25 9.25 L 10 3.75"
                                                  Stroke="White"
                                                  StrokeThickness="2.2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                        </Viewbox>
                                    </Border>

                                    <ContentPresenter Grid.Column="1"
                                                      Margin="4,0,0,0"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      RecognizesAccessKey="True" />
                                </Grid>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource ChipBrush}" />
                                <Setter TargetName="CheckRoot" Property="BorderBrush" Value="{DynamicResource MutedTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource PanelMutedBrush}" />
                                <Setter TargetName="CheckRoot" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="CheckRoot" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusRing" Property="BorderBrush" Value="{DynamicResource ButtonRingBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemRoot" Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

